{# model.py.j2 -- Odoo 18.0 Python model file with fields and constraints #}
{# 18.0 differences: group_operator -> aggregator, states= parameter removed #}
from odoo import {{ 'api, ' if needs_api }}fields, models
{% if has_constraints or constrained_fields %}
from odoo.exceptions import ValidationError
{% endif %}


class {{ model_name | to_class }}(models.Model):
    _name = "{{ model_name }}"
    _description = "{{ model_description }}"
{% if inherit_list %}
    _inherit = [{% for inh in inherit_list %}"{{ inh }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% endif %}

{% if needs_currency_id %}
    currency_id = fields.Many2one(
        comodel_name="res.currency",
        string="Currency",
        default=lambda self: self.env.company.currency_id,
    )
{% endif %}
{% for field in fields %}
{% if field.type == 'Selection' %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        selection=[
{% for opt in field.selection %}
            ("{{ opt[0] }}", "{{ opt[1] }}"),
{% endfor %}
        ],
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.default is defined %}
        default="{{ field.default }}",
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% elif field.type in ('Many2one', 'One2many', 'Many2many') %}
    {{ field.name }} = fields.{{ field.type }}(
        comodel_name="{{ field.comodel_name }}",
{% if field.type == 'One2many' %}
        inverse_name="{{ field.inverse_name }}",
{% endif %}
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% elif field.type == 'Char' and field.name in sequence_field_names and field.required %}
    {{ field.name }} = fields.Char(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        required=True,
        default=_default_{{ field.name }},
        readonly=True,
        copy=False,
    )
{% elif field.type == 'Monetary' %}
    {{ field.name }} = fields.Monetary(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        currency_field="currency_id",
{% if field.compute is defined and field.compute %}
        compute="{{ field.compute }}",
{% endif %}
{% if field.store is defined and field.store %}
        store=True,
{% endif %}
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% elif field.compute is defined and field.compute %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        compute="{{ field.compute }}",
{% if field.store is defined and field.store %}
        store=True,
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% else %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.default is defined %}
        default="{{ field.default }}",
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% endif %}
{% endfor %}
{% if sql_constraints %}

    _sql_constraints = [
{% for constraint in sql_constraints %}
        (
            "{{ constraint.name }}",
            "{{ constraint.definition }}",
            "{{ constraint.message }}",
        ),
{% endfor %}
    ]
{% endif %}
{% for field in sequence_fields %}

    @api.model
    def _default_{{ field.name }}(self):
        return self.env["ir.sequence"].next_by_code("{{ model_name }}") or "/"
{% endfor %}
{% for field in computed_fields %}

    @api.depends({% for dep in field.depends %}"{{ dep }}"{% if not loop.last %}, {% endif %}{% endfor %})
    def {{ field.compute }}(self):
        # TODO: implement — depends on {{ field.depends | join(', ') }}
        for rec in self:
            rec.{{ field.name }} = {{ 0.0 if field.type in ('Float', 'Monetary', 'Integer') else False if field.type == 'Boolean' else "''" }}
{% endfor %}
{% for field in onchange_fields %}

    @api.onchange("{{ field.name }}")
    def _onchange_{{ field.name }}(self):
        # TODO: implement onchange for {{ field.name }}
        pass
{% endfor %}
{% for field in constrained_fields %}

    @api.constrains({% for c in field.constrains %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %})
    def _check_{{ field.name }}(self):
        # TODO: implement — validate {{ field.constrains | join(', ') }}
        for rec in self:
            pass
{% endfor %}
