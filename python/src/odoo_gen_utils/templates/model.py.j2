{# model.py.j2 -- Odoo Python model file with fields and constraints #}
from odoo import api, fields, models
{% if has_constraints %}
from odoo.exceptions import ValidationError
{% endif %}


class {{ model_name | to_class }}(models.Model):
    _name = "{{ model_name }}"
    _description = "{{ model_description }}"
{% if inherit %}
    _inherit = ["{{ inherit }}"]
{% endif %}

{% for field in fields %}
{% if field.type == 'Selection' %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        selection=[
{% for opt in field.selection %}
            ("{{ opt[0] }}", "{{ opt[1] }}"),
{% endfor %}
        ],
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.default is defined %}
        default="{{ field.default }}",
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% elif field.type in ('Many2one', 'One2many', 'Many2many') %}
    {{ field.name }} = fields.{{ field.type }}(
        comodel_name="{{ field.comodel_name }}",
{% if field.type == 'One2many' %}
        inverse_name="{{ field.inverse_name }}",
{% endif %}
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% else %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
{% if field.default is defined %}
        default="{{ field.default }}",
{% endif %}
{% if field.help is defined %}
        help="{{ field.help }}",
{% endif %}
    )
{% endif %}
{% endfor %}
{% if sql_constraints %}

    _sql_constraints = [
{% for constraint in sql_constraints %}
        (
            "{{ constraint.name }}",
            "{{ constraint.definition }}",
            "{{ constraint.message }}",
        ),
{% endfor %}
    ]
{% endif %}
