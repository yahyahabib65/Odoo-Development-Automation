{# view_form.xml.j2 -- Odoo form, tree, and search views for a model #}
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_{{ model_name | to_xml_id }}_form" model="ir.ui.view">
        <field name="name">{{ model_name }}.view.form</field>
        <field name="model">{{ model_name }}</field>
        <field name="arch" type="xml">
            <form string="{{ model_description }}">
{% if state_field or model_reports %}
                <header>
                    <!-- Action buttons enriched by odoo-view-gen in generate.md Wave 2 -->
{% for wizard in wizards %}
{% if wizard.target_model == model_name %}
                    <button name="action_open_{{ wizard.name | to_xml_id }}"
                            string="{{ wizard.button_label | default('Open ' + (wizard.name | replace('.', ' ') | title)) }}"
                            type="object"
                            class="btn-primary"
{% if wizard.get('trigger_state') %}
                            invisible="{{ state_field.name }} != '{{ wizard.trigger_state }}'"/>
{% else %}
                            />
{% endif %}
{% endif %}
{% endfor %}
{% for report in model_reports %}
                    <button name="%(report_{{ module_name }}_{{ report.xml_id }})d"
                            string="{{ report.button_label | default('Print') }}"
                            type="action"
                            class="btn-secondary"/>
{% endfor %}
{% if state_field %}
                    <field name="{{ state_field.name }}" widget="statusbar"
                           statusbar_visible="{{ state_field.selection | map(attribute=0) | join(',') }}"/>
{% endif %}
                </header>
{% endif %}
                <sheet>
                    <div class="oe_title">
{% for field in view_fields | default(fields) %}
{% if field.name == 'name' %}
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Enter name..."/>
                        </h1>
{% endif %}
{% endfor %}
                    </div>
                    <group>
                        <group>
{% for field in view_fields | default(fields) %}
{% set is_state = state_field and field.name == state_field.name %}
{% if not is_state and field.name != 'name' and field.type not in ('One2many', 'Html') %}
{% if loop.index0 is even or loop.index0 < 2 %}
{% if field.name in sequence_field_names %}
                            <field name="{{ field.name }}"{% if state_field %} readonly="{{ state_field.name }} != 'draft'"{% endif %}/>
{% elif field.type == 'Many2one' %}
                            <field name="{{ field.name }}"
                                   options="{'no_create': True}"
                            />
{% else %}
                            <field name="{{ field.name }}"
                            />
{% endif %}
{% endif %}
{% endif %}
{% endfor %}
                        </group>
                        <group>
{% for field in view_fields | default(fields) %}
{% set is_state = state_field and field.name == state_field.name %}
{% if not is_state and field.name != 'name' and field.type not in ('One2many', 'Html') %}
{% if loop.index0 is odd and loop.index0 >= 2 %}
{% if field.name in sequence_field_names %}
                            <field name="{{ field.name }}"{% if state_field %} readonly="{{ state_field.name }} != 'draft'"{% endif %}/>
{% elif field.type == 'Many2one' %}
                            <field name="{{ field.name }}"
                                   options="{'no_create': True}"
                            />
{% else %}
                            <field name="{{ field.name }}"
                            />
{% endif %}
{% endif %}
{% endif %}
{% endfor %}
                        </group>
                    </group>
{% for field in view_fields | default(fields) %}
{% if field.type == 'Html' %}
                    <notebook>
                        <page string="{{ field.string | default(field.name | replace('_', ' ') | title) }}">
                            <field name="{{ field.name }}" widget="html"/>
                        </page>
                    </notebook>
{% endif %}
{% endfor %}
{% for field in view_fields | default(fields) %}
{% if field.type == 'One2many' %}
                    <notebook>
                        <page string="{{ field.string | default(field.name | replace('_', ' ') | title) }}">
                            <field name="{{ field.name }}">
                                <tree editable="bottom">
{% for submodel in models %}
{% if submodel.name == field.comodel_name %}
{% for subfield in submodel.fields %}
{% if subfield.name != field.inverse_name %}
                                    <field name="{{ subfield.name }}"/>
{% endif %}
{% endfor %}
{% endif %}
{% endfor %}
                                </tree>
                            </field>
                        </page>
                    </notebook>
{% endif %}
{% endfor %}
                </sheet>
{% if 'mail' in depends %}
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
{% endif %}
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_{{ model_name | to_xml_id }}_tree" model="ir.ui.view">
        <field name="name">{{ model_name }}.view.tree</field>
        <field name="model">{{ model_name }}</field>
        <field name="arch" type="xml">
            <tree string="{{ model_description }}">
{% for field in view_fields | default(fields) %}
{% if field.type not in ('One2many', 'Html', 'Text') %}
{% if loop.index0 < 6 %}
                <field name="{{ field.name }}"{% if loop.index0 >= 4 %} optional="hide"{% endif %}/>
{% endif %}
{% endif %}
{% endfor %}
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_{{ model_name | to_xml_id }}_search" model="ir.ui.view">
        <field name="name">{{ model_name }}.view.search</field>
        <field name="model">{{ model_name }}</field>
        <field name="arch" type="xml">
            <search string="{{ model_description }}">
{% for field in view_fields | default(fields) %}
{% if field.type in ('Char', 'Many2one') %}
                <field name="{{ field.name }}"/>
{% endif %}
{% endfor %}
{% for field in view_fields | default(fields) %}
{% if field.type == 'Selection' %}
                <filter string="Group by {{ field.string | default(field.name | replace('_', ' ') | title) }}"
                        name="group_by_{{ field.name }}"
                        context="{'group_by': '{{ field.name }}'}"/>
{% endif %}
{% endfor %}
{% for field in view_fields | default(fields) %}
{% if field.type == 'Many2one' %}
                <filter string="Group by {{ field.string | default(field.name | replace('_', ' ') | title) }}"
                        name="group_by_{{ field.name }}"
                        context="{'group_by': '{{ field.name }}'}"/>
{% endif %}
{% endfor %}
            </search>
        </field>
    </record>

</odoo>
