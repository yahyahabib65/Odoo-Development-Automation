{# import_wizard_form.xml.j2 -- Import wizard form view with state-dependent groups #}
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Import Wizard Form View -->
    <record id="view_{{ model_xml_id }}_import_wizard_form" model="ir.ui.view">
        <field name="name">{{ model_name }}.import.wizard.view.form</field>
        <field name="model">{{ model_name }}.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import {{ model_description }}">
                <group invisible="state != 'upload'">
                    <group>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                </group>
                <group invisible="state != 'preview'">
                    <field name="preview_html" nolabel="1"/>
                </group>
                <group invisible="state != 'done'">
                    <group>
                        <field name="import_count"/>
                        <field name="error_log" invisible="not error_log"/>
                    </group>
                </group>
                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_preview"
                            string="Preview"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button name="action_import"
                            string="Import"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preview'"/>
                    <button name="action_export"
                            string="Export All"
                            type="object"
                            class="btn-secondary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Import Wizard Action -->
    <record id="action_{{ model_xml_id }}_import_wizard" model="ir.actions.act_window">
        <field name="name">Import {{ model_description }}</field>
        <field name="res_model">{{ model_name }}.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
