{# wizard.py.j2 -- Odoo TransientModel wizard #}
from odoo import api, fields, models


class {{ wizard_class }}(models.TransientModel):
    _name = "{{ wizard.name }}"
    _description = "{{ wizard.name | replace('.', ' ') | title }}"

{% for field in wizard.fields %}
{% if field.type == 'Selection' %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
        selection=[
{% for opt in field.selection %}
            ("{{ opt[0] }}", "{{ opt[1] }}"),
{% endfor %}
        ],
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
    )
{% elif field.type in ('Many2one', 'One2many', 'Many2many') %}
    {{ field.name }} = fields.{{ field.type }}(
        comodel_name="{{ field.comodel_name }}",
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
    )
{% else %}
    {{ field.name }} = fields.{{ field.type }}(
        string="{{ field.string | default(field.name | replace('_', ' ') | title) }}",
{% if field.required is defined and field.required %}
        required=True,
{% endif %}
    )
{% endif %}
{% endfor %}

    @api.model
    def default_get(self, fields_list):
        res = super().default_get(fields_list)
        active_id = self.env.context.get("active_id")
        if active_id:
            res["active_id"] = active_id
        return res

    def button_confirm(self):
        self.ensure_one()
        # TODO: implement — perform action on target model {{ wizard.target_model }}
        return {"type": "ir.actions.act_window_close"}
